{
  "expo": {
    "name": "Angrez",
    "slug": "angrez-app",
    "owner": "reddot-life-09",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.angrez.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Angrez को आपकी आवाज़ सुनने के लिए अनुमति चाहिए।",
        "NSMicrophoneUsageDescription": "Angrez को बोलने के लिए माइक्रोफोन चाहिए।"
      }
    },
    "android": {
      "package": "com.angrez.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Angrez को बोलने के लिए माइक्रोफोन चाहिए।",
          "speechRecognitionPermission": "Angrez को आपकी आवाज़ सुनने के लिए अनुमति चाहिए।"
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "cc234316-bd57-4917-a6df-2b5d8bcc1182"
      }
    }
  }
}
